{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Xi",
  "scopeName": "source.xi",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#declarations" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#function-call" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.xi",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "comment": "Interpolated triple-quoted string: $\"\"\" ... ${expr} ... \"\"\"",
          "name": "string.quoted.triple.interpolated.xi",
          "begin": "\\$\"\"\"",
          "end": "\"\"\"",
          "patterns": [
            { "include": "#interpolation" }
          ]
        },
        {
          "name": "string.quoted.triple.xi",
          "begin": "\"\"\"",
          "end": "\"\"\""
        },
        {
          "comment": "Interpolated string: $\" ... ${expr} ... \"",
          "name": "string.quoted.double.interpolated.xi",
          "begin": "\\$\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.xi", "match": "\\\\." },
            { "include": "#interpolation" }
          ]
        },
        {
          "name": "string.quoted.double.xi",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.xi", "match": "\\\\." }
          ]
        }
      ]
    },
    "interpolation": {
      "patterns": [
        {
          "comment": "${ expr } hole — the expression is highlighted as code",
          "name": "meta.interpolation.xi",
          "begin": "\\$\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.template-expression.begin.xi" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.template-expression.end.xi" }
          },
          "patterns": [
            { "include": "$self" }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.hex.xi", "match": "\\b0x[0-9a-fA-F]+\\b" },
        { "name": "constant.numeric.binary.xi", "match": "\\b0b[01]+\\b" },
        { "name": "constant.numeric.float.xi", "match": "\\b[0-9]+\\.[0-9]+\\b" },
        { "name": "constant.numeric.integer.xi", "match": "\\b[0-9]+\\b" }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "comment": "Function kinds, optionally async, capturing the name (incl. extension receiver, e.g. Type.method and Type[].method)",
          "match": "\\b(async\\s+)?(mapper|projector|predicate|consumer|producer|reducer|creator|decision|action|listener|entry)\\b\\s*(?:\\{[^}]*\\}\\s*)?([A-Za-z_][A-Za-z0-9_]*(?:\\[\\])?(?:\\.[A-Za-z_][A-Za-z0-9_]*)?)?",
          "captures": {
            "1": { "name": "storage.modifier.xi" },
            "2": { "name": "storage.type.function.xi" },
            "3": { "name": "entity.name.function.xi" }
          }
        },
        {
          "comment": "type / interface / class / module / namespace + name",
          "match": "\\b(type|interface|class|module|namespace)\\b\\s*([A-Za-z_][A-Za-z0-9_.]*)?",
          "captures": {
            "1": { "name": "storage.type.xi" },
            "2": { "name": "entity.name.type.xi" }
          }
        },
        {
          "name": "keyword.declaration.xi",
          "match": "\\b(implements|extends|deps|bind|as|import|export|extern|hit|const|state|event|atom|machine|transition|interrupt|listener)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.xi",
          "match": "\\b(if|else|match|when|otherwise|for|while|loop|break|continue|return|scope|unsafe|spawn|await|async|where)\\b"
        },
        {
          "name": "storage.modifier.xi",
          "match": "\\b(singleton|transient|scoped|own|dup|let)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.xi",
          "match": "\\b(Number|Integer|Bool|String|Char|Void|Size|cstring|Bytes)\\b"
        },
        {
          "name": "entity.name.type.xi",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.xi",
          "match": "\\b(true|false|none|this|value|input)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.word.xi",
          "match": "\\b(and|or|not|is|in|matches)\\b"
        },
        {
          "name": "keyword.operator.xi",
          "match": "(=>|->|==|!=|<=|>=|\\?\\?|\\?\\.|\\+=|-=|\\*=|/=|[-+*/%<>=!?])"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "comment": "Identifier immediately followed by ( is a call",
          "match": "\\b([a-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "name": "entity.name.function.call.xi"
        }
      ]
    }
  }
}

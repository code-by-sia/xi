{
  "name": "xi-language",
  "displayName": "Xi Programming Language",
  "description": "Syntax highlighting, snippets, and completion for the Xi programming language.",
  "version": "0.1.1",
  "publisher": "code-by-sia",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/code-by-sia/xi"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:xi"
  ],
  "contributes": {
    "languages": [
      {
        "id": "xi",
        "aliases": ["Xi", "xi"],
        "extensions": [".xi", ".x"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "xi",
        "scopeName": "source.xi",
        "path": "./syntaxes/xi.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "xi",
        "path": "./snippets/xi.json"
      }
    ]
  }
}

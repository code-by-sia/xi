{
  "name": "tree-sitter-x",
  "version": "0.0.1",
  "description": "Tree-sitter grammar for the X programming language",
  "license": "Apache-2.0",
  "scripts": {
    "generate": "tree-sitter generate",
    "parse": "tree-sitter parse",
    "install": "node-gyp-build",
    "prebuildify": "prebuildify --napi --strip"
  },
  "tree-sitter": [
    {
      "scope": "source.x",
      "file-types": [
        "x"
      ],
      "highlights": [
        "queries/highlights.scm"
      ]
    }
  ],
  "dependencies": {
    "node-gyp-build": "^4.8.0"
  },
  "peerDependencies": {
    "tree-sitter": "^0.21.0"
  },
  "peerDependenciesMeta": {
    "tree_sitter": {
      "optional": true
    }
  },
  "devDependencies": {
    "prebuildify": "^6.0.0"
  },
  "types": "bindings/node",
  "files": [
    "grammar.js",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "queries/*",
    "src/**"
  ]
}

**/node_modules/
editors/tree-sitter-x/.build/

# OS / editor noise
.DS_Store
*.swp

# Zed local grammar cache
editors/zed/grammars/

# Release artifacts
*.tar.gz
/x-*/
/xi-*/

# Docusaurus
website/node_modules/
website/build/
website/.docusaurus/
